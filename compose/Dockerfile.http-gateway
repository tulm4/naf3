# Build stage: compile the http-gateway binary.
FROM golang:1.25-alpine AS builder
WORKDIR /src
COPY go.mod go.sum ./
COPY oapi-gen/ oapi-gen/
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /bin/http-gateway ./cmd/http-gateway

# Runtime stage.
FROM alpine:3.19
RUN apk add --no-cache ca-certificates
COPY --from=builder /bin/http-gateway /bin/http-gateway
COPY configs/ /etc/nssAAF/
EXPOSE 8080 8443
CMD ["/bin/http-gateway", "-config", "/etc/nssAAF/http-gateway.yaml"]
